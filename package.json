{
  "name": "ecommerce-prueba-2026",
  "version": "1.2.0",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "scripts": {
    "start": "docker-compose up -d --build",
    "stop": "docker-compose down",
    "start:fresh": "docker-compose down -v && docker-compose up -d --build",
    "test:all": "npm run test --workspaces --if-present",
    "build:all": "npm run build --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "postinstall": "npx prisma generate --schema=services/products-service/src/prisma/schema.prisma && npx prisma generate --schema=services/orders-service/src/prisma/schema.prisma || true"
  },
  "dependencies": {
    "@nestjs/platform-express": "^11.1.17",
    "@prisma/client": "^6.19.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "prisma": "^6.19.2"
  }
}
