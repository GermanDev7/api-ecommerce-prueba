{
  "info": {
    "name": "E-Commerce Gateway API",
    "_postman_id": "ecommerce-prueba-2026-gateway",
    "description": "Pruebas consolidadas del sistema E-Commerce accediendo puramente mediante el API Gateway (puerto 8080).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "product_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "📦 Products vía API Gateway",
      "item": [
        {
          "name": "1. Crear Producto - Laptop",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Obtains generated product ID', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('product_id', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro 14\",\n  \"description\": \"High-performance laptop with M3 chip\",\n  \"price\": 1299.99,\n  \"stock\": 50\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/products",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "2. Crear Producto - Mouse",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Gaming Mouse RGB\",\n  \"description\": \"Ultra-precise gaming mouse\",\n  \"price\": 79.99,\n  \"stock\": 200\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/products",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "3. Listar Todos los Productos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is valid array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/v1/products",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "4. Obtener Producto por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/v1/products/{{product_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "❌ Validaciones: Producto sin body (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/products",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "products"]
            }
          }
        }
      ]
    },
    {
      "name": "🛒 Orders vía API Gateway",
      "item": [
        {
          "name": "1. Crear Orden (con product_id guardado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Order ID captured', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('order_id', jsonData.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{product_id}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/orders",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "orders"]
            }
          }
        },
        {
          "name": "2. Listar Todas las Órdenes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/v1/orders",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "orders"]
            }
          }
        },
        {
          "name": "3. Obtener Orden por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gateway_url}}/api/v1/orders/{{order_id}}",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "❌ Validaciones: Order sin UUID (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"invalid-uuid\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{gateway_url}}/api/v1/orders",
              "host": ["{{gateway_url}}"],
              "path": ["api", "v1", "orders"]
            }
          }
        }
      ]
    }
  ]
}
